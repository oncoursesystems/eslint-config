{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "ignoreDeprecations": "6.0",
        "types": ["node"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["**/*.ts"],
    "exclude": [
        "./fixtures/**/*.*",
        "./_fixtures/**/*.*"
    ]
}
