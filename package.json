{
    "name": "@oncoursesystems/eslint-config",
    "type": "module",
    "version": "2.0.0",
    "description": "OnCourse Systems' ESLint configurations",
    "author": "OnCourse Systems For Education",
    "license": "MIT",
    "homepage": "https://github.com/oncoursesystems/eslint-config#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/oncoursesystems/eslint-config.git"
    },
    "keywords": [
        "eslint-config",
        "react",
        "react-native",
        "expo",
        "sencha",
        "extjs"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsup --format esm,cjs --clean --dts",
        "stub": "tsup --format esm",
        "dev": "npx @eslint/config-inspector --config eslint.config.ts",
        "build:inspector": "pnpm build && npx @eslint/config-inspector build",
        "watch": "tsup --format esm,cjs --watch",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prepack": "pnpm build",
        "release": "bumpp",
        "test": "vitest",
        "typecheck": "tsc --noEmit",
        "prepare": "simple-git-hooks"
    },
    "peerDependencies": {
        "@sencha/eslint-plugin-extjs": "^8.0.0",
        "@tanstack/eslint-plugin-query": "^5.101.0",
        "eslint": "^10.0.0",
        "eslint-plugin-expo": "^1.0.3",
        "eslint-plugin-tailwindcss": "^4.0.0-beta.0"
    },
    "peerDependenciesMeta": {
        "@sencha/eslint-plugin-extjs": {
            "optional": true
        },
        "@tanstack/eslint-plugin-query": {
            "optional": true
        },
        "eslint-plugin-expo": {
            "optional": true
        },
        "eslint-plugin-tailwindcss": {
            "optional": true
        }
    },
    "dependencies": {
        "@antfu/eslint-config": "^9.0.0"
    },
    "devDependencies": {
        "@eslint-react/eslint-plugin": "^5.8.12",
        "@eslint/config-inspector": "^3.0.4",
        "@sencha/eslint-plugin-extjs": "^8.0.0",
        "@tanstack/eslint-plugin-query": "^5.101.0",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^25.9.2",
        "bumpp": "^11.1.0",
        "eslint": "^10.4.1",
        "eslint-plugin-expo": "^1.0.3",
        "eslint-plugin-format": "^2.0.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-tailwindcss": "4.0.0-beta.0",
        "execa": "^9.6.1",
        "fast-glob": "^3.3.3",
        "fs-extra": "^11.3.5",
        "jiti": "^2.7.0",
        "lint-staged": "^17.0.7",
        "simple-git-hooks": "^2.13.1",
        "tsup": "^8.5.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.8"
    },
    "simple-git-hooks": {
        "pre-commit": "npx lint-staged"
    },
    "lint-staged": {
        "*": "eslint --fix"
    }
}
